# Copy to secrets.toml and fill in your values:
#   mkdir -p .streamlit
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Root-level keys are available via os.environ / functions.env.env() and
# st.secrets["KEY"]. Never commit secrets.toml.

TRELLO_API_KEY = ""
TRELLO_TOKEN = ""
TRELLO_BOARD_ID = ""
TRELLO_LIST_ID = ""

# Neon Postgres (pooled URL preferred for the Streamlit app)
# From Neon Console → Connect → copy connection string
DATABASE_URL = "postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

# Fernet key used to encrypt Trello api_key/token in app_trello_connections.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this stable — changing it makes existing encrypted credentials unreadable.
CREDENTIALS_ENCRYPTION_KEY = ""

# Resend (welcome email on account creation)
# API key: https://resend.com/api-keys
RESEND_API_KEY = ""
# Optional; defaults to "Project Management <onboarding@resend.dev>"
# Sandbox from-address can only deliver to your Resend account email.
# For production, verify a domain and set e.g. "App <noreply@yourdomain.com>"
RESEND_FROM_EMAIL = ""
